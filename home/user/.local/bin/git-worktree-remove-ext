#!/usr/bin/env bash
#
# git-worktree-remove-ext: Enhanced git worktree remove
#
# Removes the worktree and optionally deletes the associated branch.
#
# Flags:
#   -f    force remove worktree even if dirty (passed to git worktree remove)
#   -d    delete branch after removing the worktree
#   -D    force delete branch even if not fully merged
#   -d -f combined: implies -D (force delete branch)

## helpers

# Find the branch checked out in the worktree being removed.
#
# Extracts the first positional (non-flag) argument as the worktree
# location, resolves it to an absolute path, then walks the porcelain
# output of `git worktree list` to find the matching branch.
#
# Arguments:
#   $@ - the full argument list passed to the script
#
# Output:
#   The branch name (without refs/heads/ prefix), or nothing if the
#   worktree is not found or is in detached HEAD state.
get_remove_branch() {
  local location=""
  for arg in "$@"; do
    case "$arg" in
      -*) ;;
      *) location="$arg"; break ;;
    esac
  done

  [[ -z "$location" ]] && return

  local resolved current_wt=""
  resolved="$(cd "$location" 2>/dev/null && pwd -P)" || resolved="$location"
  while IFS= read -r line; do
    if [[ "$line" == "worktree "* ]]; then
      current_wt="${line#worktree }"
    elif [[ "$line" == "branch "* && "$current_wt" == "$resolved" ]]; then
      echo "${line#branch refs/heads/}"
      return
    fi
  done < <(command git worktree list --porcelain)
}

## main — only runs when executed directly, not sourced

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail

  delete_branch=false
  force_delete=false
  force_remove=false
  worktree_args=()

  for arg in "$@"; do
    case "$arg" in
      -D) delete_branch=true; force_delete=true ;;
      -d) delete_branch=true ;;
      -f|--force) force_remove=true; worktree_args+=("$arg") ;;
      *) worktree_args+=("$arg") ;;
    esac
  done

  # -d -f combined implies -D
  if $delete_branch && $force_remove; then
    force_delete=true
  fi

  # Resolve branch before removing worktree
  branch=""
  if $delete_branch; then
    branch="$(get_remove_branch "${worktree_args[@]}")"
  fi

  # Remove worktree
  command git worktree remove "${worktree_args[@]}"

  # Delete branch if requested
  if $delete_branch && [[ -n "$branch" ]]; then
    if $force_delete; then
      command git branch -D "$branch"
    else
      command git branch -d "$branch"
    fi
  fi
fi
