{
  "$schema": "https://opencode.ai/tui.json",
  "mouse": false,
  "theme": "system",
  "vim_enter_submit": true,
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+d,<leader>q",
    "editor_open": "ctrl+g",
    "input_buffer_end": "ctrl+end",
    "input_buffer_home": "ctrl+home",
    "input_line_end": "end",
    "input_line_home": "home",
    "input_submit": "return,<leader>return",
    "messages_first": "shift+home",
    "messages_last": "shift+end",
    "messages_line_down": "shift+down",
    "messages_line_up": "shift+up",
    "session_interrupt": "escape,ctrl+c"
  }
}
